# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_DEFAULT_REGION=eu-north-1
S3_BUCKET_NAME=nordiclens-raw

# ── Snowflake ─────────────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=your_account_identifier        # e.g. abc123.eu-west-1
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=NORDICLENS_ROLE
SNOWFLAKE_WAREHOUSE=NORDICLENS_WH
SNOWFLAKE_DATABASE=NORDICLENS_DB
SNOWFLAKE_RAW_SCHEMA=RAW
SNOWFLAKE_STAGING_SCHEMA=STAGING
SNOWFLAKE_INTERMEDIATE_SCHEMA=INTERMEDIATE
SNOWFLAKE_MARTS_SCHEMA=MARTS

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW__CORE__FERNET_KEY=your_fernet_key        # generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW_UID=50000

# ── dbt ───────────────────────────────────────────────────────────────────────
DBT_PROFILES_DIR=~/.dbt
DBT_TARGET=dev
